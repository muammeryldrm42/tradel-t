{
  "name": "@lighter-bot/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "start:railway": "node -e \"const {execSync}=require('child_process');try{execSync('npx prisma db push --accept-data-loss',{stdio:'inherit'})}catch(e){console.log('DB push failed, continuing...')}\" && node dist/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push --accept-data-loss",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lighter-bot/common": "*",
    "@lighter-bot/strategy": "*",
    "@lighter-bot/risk": "*",
    "@lighter-bot/execution": "*",
    "@lighter-bot/backtest": "*",
    "fastify": "^5.2.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/websocket": "^11.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@prisma/client": "^6.2.1",
    "decimal.js": "^10.4.3",
    "pino": "^9.6.0",
    "zod": "^3.24.1",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "prisma": "^6.2.1"
  }
}
